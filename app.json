{
  "expo": {
    "name": "Trimly",
    "slug": "trimly",
    "scheme": "trimly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E27"
    },
    "backgroundColor": "#0A0E27",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trimly.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.572874464830-be4rip5fsce1ku3nrep481uhvmuja0to"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0A0E27"
      },
      "package": "com.trimly.app",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "trimly"
            },
            {
              "scheme": "com.googleusercontent.apps.572874464830-be4rip5fsce1ku3nrep481uhvmuja0to"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5B3BF5",
          "sounds": []
        }
      ],
      "expo-web-browser",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "da2b6681-aa08-4871-95ac-b511a08b14ba"
      }
    }
  }
}
