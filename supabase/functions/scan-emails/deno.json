{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "imports": {
    "deno:": "https://deno.land/",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@2.39.0"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-env --watch src/index.ts",
    "start": "deno run --allow-net --allow-env src/index.ts"
  },
  "compilerOptions": {
    "allowJs": true,
    "lib": ["deno.window"]
  },
  "exclude": ["**/_from_node_modules/**"],
  "lint": {
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules/**"],
    "rules": {
      "tags": ["recommended"],
      "include": ["ban-untagged-todo"],
      "exclude": ["no-unused-vars"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules/**"]
  },
  "test": {
    "include": ["src/**/*.test.ts"],
    "exclude": ["node_modules/**"]
  },
  "deploy": {
    "project": "trimly",
    "region": "eu-west-1"
  }
}
